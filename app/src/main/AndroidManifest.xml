<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Outbound SIP calling needs the network for signaling + media. The full
        calling permission surface (RECORD_AUDIO, MANAGE_OWN_CALLS,
        FOREGROUND_SERVICE_*, the CallRedirectionService role, etc.) is
        specified in SPEC.md "Permissions" and is added alongside the Telecom /
        Linphone implementation it backs, so the app never holds a permission
        it doesn't yet use.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Analytics ad-id is never collected; strip the transitively-merged perm. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />

    <!--
        The Linphone SDK's AAR manifest-merges a broad calling permission set
        (RECORD_AUDIO, the FOREGROUND_SERVICE_* family, BLUETOOTH, WAKE_LOCK,
        VIBRATE, …). Per SPEC.md "Permissions", Phomo declares a permission only
        alongside the code that uses it — and this dependency-introduction step
        ships no calling code yet, so every SDK-injected permission is removed
        here. Each is re-added (drop its `tools:node="remove"` line) in the
        milestone that introduces the feature needing it: RECORD_AUDIO /
        MODIFY_AUDIO_SETTINGS / the FOREGROUND_SERVICE_* + WAKE_LOCK / BLUETOOTH
        set with the in-call audio path (Milestone 3); the WiFi/notification/
        vibrate permissions are inbound-ringing / discovery features Phomo's
        outbound-only v1 never uses and stay removed.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" tools:node="remove" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" tools:node="remove" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" tools:node="remove" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" tools:node="remove" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" tools:node="remove" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" tools:node="remove" />
    <uses-permission android:name="android.permission.WAKE_LOCK" tools:node="remove" />
    <uses-permission android:name="android.permission.BLUETOOTH" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" tools:node="remove" />
    <uses-permission android:name="android.permission.VIBRATE" tools:node="remove" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Phomo">

        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
